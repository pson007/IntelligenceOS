# Copy to .env and fill in. Never commit .env.

# Shared secret used to HMAC-sign payloads from the Cloudflare Worker to this bridge.
# Generate with: python3 -c 'import secrets; print(secrets.token_urlsafe(32))'
BRIDGE_SHARED_SECRET=

# Bridge server bind config
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# Path to the persistent Playwright user-data directory (logged-in TradingView session).
# Used only in LAUNCH mode (i.e. when TV_CDP_URL is unset).
# Default: ./session  (relative to the tradingview/ dir)
TV_SESSION_DIR=./session

# Run Playwright headless? Set to "false" during initial debugging so you can watch.
# Used only in LAUNCH mode.
TV_HEADLESS=true

# ATTACH MODE (recommended): drive your real Chrome instead of launching a
# separate Chromium. Requires Chrome to be running with --remote-debugging-port.
# Easiest path:
#   1. ./start_chrome_cdp.sh        (quits + relaunches Chrome on port 9222)
#   2. Uncomment the line below.
#   3. Run any script — it'll attach to your Chrome and reuse the TradingView
#      tab you already have open and signed in.
# TV_CDP_URL=http://localhost:9222

# ---- LLM providers --------------------------------------------------------
# The vision-loop driver (tv act / UI Act tab) defaults to OLLAMA —
# local inference, no API key required. Install + run Ollama, pull a
# model (e.g. `ollama pull qwen3.5:27b` or a VL model like
# `qwen2.5vl:7b`), and it just works.
#
# Anthropic Claude is OPTIONAL — used only when you pass
# `--provider anthropic` (CLI) or select it in the UI. Leave this blank
# to disable that path entirely.
ANTHROPIC_API_KEY=
# Optional model override for analyze_chart.py (Anthropic only).
# ANTHROPIC_MODEL=claude-sonnet-4-5

# ---- UI Console (ui_server.py) --------------------------------------------
# Optional shared-secret token for the web console. Leave empty for
# localhost-only access (recommended for single-user machines).
# When set, every /api/* request must carry `X-UI-Token: <value>`.
# Stash client-side via DevTools:
#   localStorage.setItem('ios-ui-token', '<value>')
# UI_TOKEN=
