# Python
.venv/
__pycache__/
*.pyc
.pytest_cache/

# Persistent Playwright session — contains TradingView login cookies, NEVER commit
session/

# Secrets
.env
.env.local

# Local logs / screenshots
logs/
screenshots/

# Action audit log — personal trade history, request IDs
audit/

# Decision log SQLite DB — per-decision rows for calibration /
# outcome reconciliation. Same privacy class as audit/. Never commit.
decisions.db
decisions.db-journal
decisions.db-wal
decisions.db-shm

# Parse-failure dumps — raw LLM output saved when JSON parsing fails.
# Useful for debugging but can contain long model reasoning; keep local.
pine/parse_failures/

# Chart screenshots + metadata captured by capture_chart.py — ephemeral
pine/captures/

# Pine files generated by analyze_and_apply.py during runs — ephemeral.
# Useful template scripts live at pine/ root (webhook_alert.pine,
# broken_test.pine); only the generated/ subdir is ignored.
pine/generated/

# Probe snapshots at tv_automation/probes/snapshots/ ARE committed
# (small JSON catalogs, useful for selector-drift diffing over time).

# Replay bench per-run checkpoints — ephemeral, rebuildable from
# decisions.db. `benchmarks/` itself IS tracked (live_bench_results.json
# lives there); just the transient replay-run files are ignored.
benchmarks/replay_bench_*.jsonl
