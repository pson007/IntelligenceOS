.claude/
*.png
# Profile screenshots travel with the JSON they describe — committed
# alongside the artifact so the Profiles UI doesn't 404 on machines
# without the user's local ~/Desktop/TradingView/ cache.
!tradingview/profiles/*.png
.DS_Store

# Coach Sketchpad runtime data — same lifecycle as audit/: per-day
# user state (accepted visuals, chat threads, proposal logs). Don't
# travel with the repo.
tradingview/sketchpad/*.json
tradingview/sketchpad/*.jsonl

# Action-recorder traces — captured user input on TradingView.
# Per-session JSONL, often contains chart screenshots/URLs in the
# clear; treat as local-only debug artifacts.
tradingview/recordings/*.jsonl
